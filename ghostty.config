theme = Apple System Colors

font-family = JetBrainsMono Nerd Font
font-size = 14

command = /opt/homebrew/bin/fish -c "tmux attach || tmux"
shell-integration = fish
mouse-hide-while-typing = true
copy-on-select = clipboard
cursor-style = bar
cursor-style-blink = false

confirm-close-surface = false
macos-titlebar-style = hidden
gtk-tabs-location = bottom
window-save-state = always
macos-option-as-alt = left

scrollback-limit = 10000

# tmux window switching (cmd+1-9 sends prefix + number)
keybind = super+physical:one=text:\x061
keybind = super+physical:two=text:\x062
keybind = super+physical:three=text:\x063
keybind = super+physical:four=text:\x064
keybind = super+physical:five=text:\x065
keybind = super+physical:six=text:\x066
keybind = super+physical:seven=text:\x067
keybind = super+physical:eight=text:\x068
keybind = super+physical:nine=text:\x069

# tmux new window (cmd+t) and close pane (cmd+w)
keybind = super+t=text:\x06c
keybind = super+w=text:\x06x

# tmux splits (cmd+d vertical, cmd+shift+d horizontal)
keybind = super+d=text:\x06v
keybind = super+shift+d=text:\x06s
